---
// src/pages/index.astro
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Optics Engineering: Advanced Wrap Dynamics</title>
		<style>
			:root {
				--bg: #fdfdfc;
				--text: #1a1a1a;
				--accent: #2563eb;
				--border: #e5e7eb;
			}
			body {
				font-family: system-ui, -apple-system, sans-serif;
				background-color: var(--bg);
				color: var(--text);
				line-height: 1.6;
				margin: 0;
				padding: 2rem 1rem;
			}
			article { max-width: 900px; margin: 0 auto; }
			h1 { font-size: 2.5rem; letter-spacing: -0.02em; margin-bottom: 0.5rem; }
			p { font-size: 1.125rem; color: #374151; margin-bottom: 1.5rem; }
			.simulator-card {
				background: white;
				border: 1px solid var(--border);
				border-radius: 12px;
				padding: 2rem;
				margin: 3rem 0;
				box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
			}
			.controls {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5rem;
				margin-bottom: 2rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--border);
			}
			.control-group { display: flex; flex-direction: column; gap: 0.5rem; }
			label { font-weight: 600; font-size: 0.875rem; }
			select, input[type="range"] { width: 100%; padding: 0.5rem; }
			.visuals {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
			}
			canvas {
				width: 100%;
				background: #f8fafc;
				border: 1px solid var(--border);
				border-radius: 8px;
			}
			.canvas-label {
				text-align: center; font-weight: 600; margin-top: 0.5rem;
				font-size: 0.875rem; color: #4b5563;
			}
		</style>
	</head>
	<body>
		<article>
			<h1>Advanced Wrap Dynamics: The Base Curve</h1>
			<p>A true sports simulation requires understanding the <strong>Base Curve</strong>. The Base Curve dictates the physical curvature of the front of the lens. A low base curve (Base 2-4) is flat, while a high base curve (Base 8-10) wraps around the skull.</p>
			
			<p>Notice how increasing the Base Curve changes the physical geometry of the lens in the simulation below. Even with a high Base 8 curve that physically fits a sports frame, a standard Spheric architecture will fail optically because the visual axis is misaligned. Freeform calculation is required to align the optical properties with the physical wrap.</p>

			<div class="simulator-card">
				<div class="controls">
					<div class="control-group">
						<label for="lensType">Lens Architecture</label>
						<select id="lensType">
							<option value="spheric">Standard Spheric</option>
							<option value="freeform">Digitally Compensated (Freeform)</option>
						</select>
					</div>
					<div class="control-group">
						<label for="wrapAngle">Frame Wrap Angle: <span id="wrapVal">15</span>°</label>
						<input type="range" id="wrapAngle" min="0" max="30" value="15">
					</div>
					<div class="control-group">
						<label for="baseCurve">Base Curve: <span id="baseVal">8</span></label>
						<input type="range" id="baseCurve" min="2" max="10" value="8">
					</div>
				</div>

				<div class="visuals">
					<div>
						<canvas id="rayCanvas" width="400" height="300"></canvas>
						<div class="canvas-label">Ray Tracing & Lens Geometry</div>
					</div>
					<div>
						<canvas id="gridCanvas" width="400" height="300"></canvas>
						<div class="canvas-label">Peripheral Vision Simulator</div>
					</div>
				</div>
			</div>
		</article>

		<script>
			const lensType = document.getElementById('lensType');
			const wrapAngle = document.getElementById('wrapAngle');
			const baseCurve = document.getElementById('baseCurve');
			const wrapVal = document.getElementById('wrapVal');
			const baseVal = document.getElementById('baseVal');
			const rayCtx = document.getElementById('rayCanvas').getContext('2d');
			const gridCtx = document.getElementById('gridCanvas').getContext('2d');

			function drawSimulator() {
				const type = lensType.value;
				const angle = parseInt(wrapAngle.value);
				const curve = parseInt(baseCurve.value);
				
				wrapVal.innerText = angle;
				baseVal.innerText = curve;
				
				drawRayTrace(type, angle, curve);
				drawGrid(type, angle, curve);
			}

			function drawRayTrace(type, angle, curve) {
				rayCtx.clearRect(0, 0, 400, 300);
				
				// Draw Eye
				rayCtx.beginPath(); rayCtx.arc(320, 150, 40, 0, Math.PI * 2);
				rayCtx.strokeStyle = '#333'; rayCtx.lineWidth = 2; rayCtx.stroke();
				rayCtx.fillStyle = '#fff'; rayCtx.fill();
				
				// Draw Retina target
				rayCtx.beginPath(); rayCtx.arc(360, 150, 4, 0, Math.PI * 2);
				rayCtx.fillStyle = 'red'; rayCtx.fill();

				// Draw Lens Geometry
				rayCtx.save();
				rayCtx.translate(200, 150);
				rayCtx.rotate((angle * Math.PI) / 180);
				
				// Morph physical curve based on Base Curve slider
				const curveStr = curve * 8; 
				rayCtx.beginPath();
				rayCtx.moveTo(0, -90);
				rayCtx.quadraticCurveTo(curveStr, 0, 0, 90); // Front surface
				rayCtx.quadraticCurveTo(curveStr - 15, 0, 0, -90); // Back surface
				
				rayCtx.fillStyle = 'rgba(37, 99, 235, 0.3)'; rayCtx.fill();
				rayCtx.strokeStyle = '#2563eb'; rayCtx.stroke();
				rayCtx.restore();

				// Draw Light Rays
				rayCtx.strokeStyle = 'rgba(250, 204, 21, 0.8)'; 
				rayCtx.lineWidth = 2;

				const rays = [-40, -20, 0, 20, 40];
				rays.forEach(yOffset => {
					rayCtx.beginPath();
					rayCtx.moveTo(0, 150 + yOffset);
					rayCtx.lineTo(200, 150 + yOffset);
					
					let deviation = 0;
					if (type === 'spheric') {
						// Distortion relies on wrap tilt and base curve physics
						const flatError = (10 - curve) * 0.5;
						deviation = ((angle / 30) * yOffset * 1.5) + (flatError * (yOffset/40)); 
					}
					
					rayCtx.lineTo(360, 150 + deviation);
					rayCtx.stroke();
				});
			}

			function drawGrid(type, angle, curve) {
				gridCtx.clearRect(0, 0, 400, 300);
				gridCtx.strokeStyle = '#9ca3af';
				gridCtx.lineWidth = 1;

				let distortionLevel = 0;
				if (type === 'spheric') {
					distortionLevel = ((angle / 30) * 15) + ((10 - curve) * 1.5);
				}

				for (let x = 0; x <= 400; x += 40) {
					gridCtx.beginPath(); gridCtx.moveTo(x, 0);
					for (let y = 0; y <= 300; y += 10) {
						let dx = x - 200, dy = y - 150;
						let distance = Math.sqrt(dx*dx + dy*dy);
						let distortAmount = 1 + (distance * distortionLevel) / 10000;
						gridCtx.lineTo(200 + dx * distortAmount, 150 + dy * distortAmount);
					}
					gridCtx.stroke();
				}

				for (let y = 0; y <= 300; y += 40) {
					gridCtx.beginPath(); gridCtx.moveTo(0, y);
					for (let x = 0; x <= 400; x += 10) {
						let dx = x - 200, dy = y - 150;
						let distance = Math.sqrt(dx*dx + dy*dy);
						let distortAmount = 1 + (distance * distortionLevel) / 10000;
						gridCtx.lineTo(200 + dx * distortAmount, 150 + dy * distortAmount);
					}
					gridCtx.stroke();
				}
			}

			lensType.addEventListener('change', drawSimulator);
			wrapAngle.addEventListener('input', drawSimulator);
			baseCurve.addEventListener('input', drawSimulator);
			drawSimulator();
		</script>
	</body>
</html>
